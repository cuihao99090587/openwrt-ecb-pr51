From: Xiaoxue <xiaoxue@users.noreply.github.com>
Date: Tue, 19 May 2026 09:30:00 +0800
Subject: [PATCH] rockchip: add image build target for Lenovo ECB-PR51

Add image build recipe for the Lenovo ECB-PR51 RK3568 board.
Uses rock-3a u-boot (generic rk3568 ddr4 1560MHz config).

Signed-off-by: Xiaoxue <xiaoxue@users.noreply.github.com>

--- a/target/linux/rockchip/image/armv8.mk
+++ b/target/linux/rockchip/image/armv8.mk
@@ -14,6 +14,15 @@ define Device/rk3568
   KERNEL_LOADADDR := 0x03000000
 endef

+define Device/lenovo_ecb-pr51
+  $(Device/rk3568)
+  DEVICE_VENDOR := Lenovo
+  DEVICE_MODEL := ECB-PR51
+  DEVICE_DTS := rk3568-ecb-pr51
+  UBOOT_DEVICE_NAME := rock-3a-rk3568
+  DEVICE_PACKAGES := kmod-r8169 blkdiscard
+endef
+TARGET_DEVICES += lenovo_ecb-pr51
+
 define Device/rk3576
   SOC := rk3576
   KERNEL_LOADADDR := 0x43000000
